{
  "crons": [
    {
      "path": "/api/broadcast?cron=morning_daily",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/broadcast?cron=night_daily",
      "schedule": "0 15 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
